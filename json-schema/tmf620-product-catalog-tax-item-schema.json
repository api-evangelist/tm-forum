{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/tm-forum/refs/heads/main/json-schema/tmf620-product-catalog-tax-item-schema.json",
  "title": "TaxItem",
  "description": "TaxItem schema from TM Forum API",
  "allOf": [
    {
      "$ref": "#/components/schemas/Extensible"
    },
    {
      "type": "object",
      "description": "A tax item is created for each tax rate and tax type used in the bill.",
      "properties": {
        "taxAmount": {
          "$ref": "#/components/schemas/Money"
        },
        "taxCategory": {
          "type": "string",
          "description": "Tax category"
        },
        "taxRate": {
          "type": "number",
          "format": "float",
          "description": "Applied rate of the tax"
        }
      }
    }
  ],
  "discriminator": {
    "propertyName": "@type",
    "mapping": {
      "TaxItem": "#/components/schemas/TaxItem"
    }
  }
}